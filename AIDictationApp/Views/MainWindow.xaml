<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="AIDictationApp.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:AIDictationApp.Helpers"
    Title="AI Dictation">

    <Grid Padding="30">
        <Grid.Resources>
            <helpers:RecordedStateToVisibilityConverter x:Key="RecordedStateToVisibility"/>
            <helpers:IdleStateToVisibilityConverter x:Key="IdleStateToVisibility"/>
            <helpers:PauseIconConverter x:Key="PauseIconConverter"/>
            <helpers:RecordingTimeFormatConverter x:Key="RecordingTimeFormatConverter"/>
            <Style x:Key="RoundIconButton" TargetType="Button">
                <Setter Property="Width" Value="64"/>
                <Setter Property="Height" Value="64"/>
                <Setter Property="CornerRadius" Value="32"/>
                <Setter Property="FontSize" Value="22"/>
            </Style>
        </Grid.Resources>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Spacing="18">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="AI Dictation" FontSize="32" FontWeight="Bold"/>
                        <TextBlock Text="Voice transcription powered by AI" Opacity="0.7" Margin="0,4,0,0"/>
                    </StackPanel>

                    <ComboBox Grid.Column="1" 
                              VerticalAlignment="Top" 
                              HorizontalAlignment="Right" 
                              Margin="0,10,10,0"
                              ItemsSource="{Binding AvailableLanguages}" 
                              SelectedItem="{Binding InputLanguage, Mode=TwoWay}"
                              Width="150" />

                    <Button x:Name="SettingsButton" Grid.Column="2" VerticalAlignment="Top" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" CornerRadius="8" Padding="10" ToolTipService.ToolTip="Settings" Click="SettingsButton_Click">
                        <FontIcon Glyph="&#xE713;" FontSize="20"/>
                    </Button>
                </Grid>

                <TextBlock
                    Text="Microphone Level"
                    FontWeight="SemiBold"/>

                <ProgressBar
                    Value="{Binding AudioLevel}"
                    Minimum="0"
                    Maximum="100"
                    Height="8"
                    IsIndeterminate="False"/>

                <TextBlock
                    Text="Transcript"
                    FontWeight="SemiBold"/>

            </StackPanel>

            <TextBox
                x:Name="TranscriptTextBox"
                Grid.Row="1"
                Margin="0,18,0,18"
                Text="{Binding Transcript, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                AcceptsReturn="True"
                ScrollViewer.VerticalScrollBarVisibility="Auto"
                TextWrapping="Wrap"
                CornerRadius="8"
                PlaceholderText="Your transcript will appear here"/>

            <StackPanel
                Grid.Row="2"
                Orientation="Vertical"
                Spacing="12">

                <StackPanel
                    Orientation="Horizontal"
                    Spacing="12">
                    <StackPanel.ChildrenTransitions>
                        <TransitionCollection>
                            <RepositionThemeTransition/>
                            <EntranceThemeTransition/>
                        </TransitionCollection>
                    </StackPanel.ChildrenTransitions>

                    <Button
                        Content="{Binding RecordButtonText}"
                        Command="{Binding RecordCommand}"
                        Visibility="{Binding State, Converter={StaticResource IdleStateToVisibility}}"
                        CornerRadius="20"
                        Height="45"
                        FontSize="16"/>

                    <StackPanel Orientation="Horizontal" Spacing="12" Visibility="{Binding State, Converter={StaticResource RecordedStateToVisibility}}">
                        <StackPanel.ChildrenTransitions>
                            <TransitionCollection>
                                <EntranceThemeTransition/>
                                <RepositionThemeTransition/>
                            </TransitionCollection>
                        </StackPanel.ChildrenTransitions>

                        <Button
                            Command="{Binding TrashCommand}"
                            CornerRadius="20"
                            Height="45"
                            Width="60"
                            ToolTipService.ToolTip="Discard">
                            <TextBlock Text="🗑" FontSize="18"/>
                        </Button>

                        <Button
                            Command="{Binding SendCommand}"
                            CornerRadius="20"
                            Height="45"
                            MinWidth="140"
                            Background="{ThemeResource AccentFillColorDefaultBrush}">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock Text="➤" FontSize="18" VerticalAlignment="Center" FontWeight="Bold"/>
                                <TextBlock Text="Send" FontSize="16" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding RecordingTime, Converter={StaticResource RecordingTimeFormatConverter}}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button
                            Command="{Binding PauseCommand}"
                            CornerRadius="20"
                            Height="45"
                            Width="60"
                            ToolTipService.ToolTip="Pause/Resume">
                            <TextBlock Text="{Binding IsPaused, Converter={StaticResource PauseIconConverter}}" FontSize="18"/>
                        </Button>

                    </StackPanel>

                    <Button
                        Command="{Binding UndoCommand}"
                        CornerRadius="8"
                        ToolTipService.ToolTip="Undo">
                        <FontIcon Glyph="&#xE7A7;" FontSize="16"/>
                    </Button>

                    <Button
                        Command="{Binding RedoCommand}"
                        CornerRadius="8"
                        ToolTipService.ToolTip="Redo">
                        <FontIcon Glyph="&#xE7A6;" FontSize="16"/>
                    </Button>

                    <Button
                        Content="Reword"
                        CornerRadius="8">
                        <Button.Flyout>
                            <Flyout>
                                <Grid MaxWidth="400">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Apply Rewording" FontWeight="Bold" Margin="0,0,0,10" Grid.Row="0"/>
                                    <ItemsControl ItemsSource="{Binding RewordingPrompts}" Grid.Row="1">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding Name}"
                                                        Command="{Binding ApplyCommand}"
                                                        Margin="0,0,5,5"
                                                        HorizontalAlignment="Stretch"
                                                        HorizontalContentAlignment="Left"
                                                        CornerRadius="6"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <VariableSizedWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="3"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </Grid>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="12">

                    <Button
                        Content="Insert"
                        Command="{Binding InsertCommand}"
                        CornerRadius="8"
                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                        FontWeight="SemiBold"/>

                    <Button
                        Content="Copy"
                        Command="{Binding CopyCommand}"
                        CornerRadius="8"/>

                    <Button
                        Content="Select All"
                        Command="{Binding SelectAllCommand}"
                        CornerRadius="8"/>

                    <Button
                        Content="Clear All"
                        Command="{Binding ClearAllCommand}"
                        CornerRadius="8"/>
                </StackPanel>

            </StackPanel>

        </Grid>

        <!-- Overlay Settings Panel -->
        <Border x:Name="SettingsPanel"
                Visibility="Collapsed"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,50,0,0"
                Width="Auto"
                MinWidth="300"
                Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock Text="Settings" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button Click="CloseSettings_Click" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Padding="8" CornerRadius="8" ToolTipService.ToolTip="Close Settings">
                        <FontIcon Glyph="&#xE711;" FontSize="14"/>
                    </Button>
                </Grid>

                <StackPanel Grid.Row="1" Spacing="8">
                    <ToggleSwitch Header="Always on top" IsOn="{Binding AlwaysOnTop, Mode=TwoWay}"/>
                    <ToggleSwitch Header="Launch at startup" IsOn="{Binding LaunchAtStartup, Mode=TwoWay}"/>
                    <ToggleSwitch Header="Keep running in background" IsOn="{Binding KeepRunningInBackground, Mode=TwoWay}"/>
                    <Button Content="API Settings" Click="OpenApiSettings_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="12" CornerRadius="8" Background="Transparent" BorderThickness="0"/>
                    <Button Content="Customize Rewording Prompts" Click="OpenCustomizePrompts_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="12" CornerRadius="8" Background="Transparent" BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Overlay API Settings Panel -->
        <Border x:Name="ApiSettingsPanel"
                Visibility="Collapsed"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,50,0,0"
                Width="Auto"
                MinWidth="350"
                MaxWidth="500"
                Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Click="BackToSettings_Click" Background="Transparent" BorderThickness="0" Padding="8" CornerRadius="8" ToolTipService.ToolTip="Back">
                        <FontIcon Glyph="&#xE72B;" FontSize="14"/>
                    </Button>
                    <TextBlock Grid.Column="1" Text="API Settings" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="12,0,0,0"/>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="8" Padding="0,0,10,0">
                        <TextBlock Text="Transcription API Settings" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,0"/>
                        <TextBlock Text="API Key" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding TranscriptionApiKey, Mode=TwoWay}" PlaceholderText="Enter API key" CornerRadius="8"/>
                        <TextBlock Text="Custom Server Host" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding TranscriptionHost, Mode=TwoWay}" PlaceholderText="e.g. https://api.openai.com/v1" CornerRadius="8"/>
                        <TextBlock Text="Model" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding TranscriptionModel, Mode=TwoWay}" PlaceholderText="e.g. whisper-1" CornerRadius="8"/>

                        <MenuFlyoutSeparator Margin="0,16"/>

                        <TextBlock Text="Rewording API Settings" FontWeight="SemiBold" FontSize="16" Margin="0,4,0,0"/>
                        <TextBlock Text="API Key" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding RewordingApiKey, Mode=TwoWay}" PlaceholderText="Enter API key" CornerRadius="8"/>
                        <TextBlock Text="Custom Server Host" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding RewordingHost, Mode=TwoWay}" PlaceholderText="e.g. https://api.openai.com/v1" CornerRadius="8"/>
                        <TextBlock Text="Model" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding RewordingModel, Mode=TwoWay}" PlaceholderText="e.g. gpt-4o-mini" CornerRadius="8"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Overlay Customize Prompts Panel -->
        <Border x:Name="CustomizePromptsPanel"
                Visibility="Collapsed"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,50,0,0"
                Width="Auto"
                MinWidth="400"
                MaxWidth="650"
                Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Click="BackToSettings_Click" Background="Transparent" BorderThickness="0" Padding="8" CornerRadius="8" ToolTipService.ToolTip="Back">
                        <FontIcon Glyph="&#xE72B;" FontSize="14"/>
                    </Button>
                    <TextBlock Grid.Column="1" Text="Customize Rewording Prompts" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="12,0,0,0"/>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="8" Padding="0,0,10,0">
                        <Button Content="Add New Prompt" Command="{Binding AddPromptCommand}" CornerRadius="8" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                        <ItemsControl ItemsSource="{Binding RewordingPrompts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBox Grid.Row="0" Grid.Column="0" Text="{Binding Name, Mode=TwoWay}" PlaceholderText="Prompt Name" FontWeight="Bold" Margin="0,0,8,8" />
                                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right">
                                                <Button Command="{Binding MoveUpCommand}" Background="Transparent" BorderThickness="0" Padding="4" ToolTipService.ToolTip="Move Up">
                                                    <FontIcon Glyph="&#xE70E;" FontSize="12"/>
                                                </Button>
                                                <Button Command="{Binding MoveDownCommand}" Background="Transparent" BorderThickness="0" Padding="4" ToolTipService.ToolTip="Move Down">
                                                    <FontIcon Glyph="&#xE70D;" FontSize="12"/>
                                                </Button>
                                                <Button Command="{Binding RemoveCommand}" Background="Transparent" BorderThickness="0" Padding="4" ToolTipService.ToolTip="Delete">
                                                    <FontIcon Glyph="&#xE74D;" FontSize="12" Foreground="Red"/>
                                                </Button>
                                            </StackPanel>

                                            <TextBox Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Instructions, Mode=TwoWay}" PlaceholderText="Rewording Instructions" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" Margin="0,0,0,8"/>

                                            <ToggleSwitch Grid.Row="2" Grid.ColumnSpan="2" Header="Apply Automatically" IsOn="{Binding ApplyAutomatically, Mode=TwoWay}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="Save Manual Edits" Command="{Binding ManualSaveCommand}" CornerRadius="8" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

    </Grid>

</Window>